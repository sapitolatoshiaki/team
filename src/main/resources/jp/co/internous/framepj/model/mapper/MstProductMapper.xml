<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper
	namespace="jp.co.internous.framepj.model.mapper.MstProductMapper">

	<select id="findByCategoryAndProductName"
		resultType="jp.co.internous.framepj.model.domain.MstProduct">
		SELECT
			image_full_path,
			product_name,
			price,
			id
		FROM
			mst_product
		WHERE
			category_id = #{category}
		<if test="keywords != null">
			AND(
			<foreach collection="keywords" item="word" separator="OR">
				product_name
				LIKE CONCAT('%', #{word}, '%')
			</foreach>
			)
		</if>
	</select>

	<select id="findByProductName"
		resultType="jp.co.internous.framepj.model.domain.MstProduct">
		SELECT
			image_full_path,
			product_name,
			price,
			id
		FROM
			mst_product
		WHERE(
		<foreach collection="keywords" item="word" separator="OR">
			product_name
			LIKE CONCAT('%', #{word}, '%')
		</foreach>
		)
	</select>

</mapper>